#!/command/with-contenv sh
exec 2>&1
if [ "${ENABLE_CONFIG_EDITOR:-true}" != "true" ]; then
    echo "config-editor: disabled via add-on options"
    exec sleep infinity
fi
CONFIG=/config/config-editor.yaml
if [ ! -f "$CONFIG" ]; then
    echo "config-editor: $CONFIG not found — service disabled"
    exec sleep infinity
fi
exec /app/.venv/bin/python -m config_editor --config "$CONFIG"
