#!/command/with-contenv sh
exec 2>&1
if [ "${ENABLE_REPORTER:-true}" != "true" ]; then
    echo "reporter: disabled via add-on options"
    /command/s6-svc -d /run/service/reporter
    exit 0
fi
CONFIG=/config/reporter.yaml
if [ ! -f "$CONFIG" ]; then
    echo "reporter: $CONFIG not found — service disabled"
    /command/s6-svc -d /run/service/reporter
    exit 0
fi
exec /app/.venv/bin/python -m reporter --config "$CONFIG"
