#!/usr/bin/with-contenv sh
exec 2>&1
if [ "${ENABLE_PV_FETCHER:-true}" != "true" ]; then
    echo "pv-fetcher: disabled via add-on options"
    exec sleep infinity
fi
CONFIG=/config/pv-fetcher.yaml
if [ ! -f "$CONFIG" ]; then
    echo "pv-fetcher: $CONFIG not found — service disabled"
    exec sleep infinity
fi
exec /app/.venv/bin/python -m pv_fetcher --config "$CONFIG"
