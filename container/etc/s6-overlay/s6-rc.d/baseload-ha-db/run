#!/command/with-contenv sh
exec 2>&1
if [ "${ENABLE_BASELOAD_HA_DB:-true}" != "true" ]; then
    echo "baseload-ha-db: disabled via add-on options"
    /command/s6-svc -d /run/service/baseload-ha-db
    exit 0
fi
CONFIG=/config/baseload-ha-db.yaml
if [ ! -f "$CONFIG" ]; then
    echo "baseload-ha-db: $CONFIG not found — service disabled"
    /command/s6-svc -d /run/service/baseload-ha-db
    exit 0
fi
exec /app/.venv/bin/python -m baseload_ha_db --config "$CONFIG"
